# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# Anthropic
ANTHROPIC_API_KEY=

# Embeddings (choose one)
VOYAGE_API_KEY=
OPENAI_API_KEY=
EMBEDDING_PROVIDER=voyage
EMBEDDING_MODEL=voyage-3
EMBEDDING_DIMS=1024

# Enrichment
LASTFM_API_KEY=
MUSICBRAINZ_USER_AGENT=music-dashboard/0.1 (your@email.com)

# Optional: live web search at Discover time. Augments the editorial signal
# with fresh hits matching the user's prompt. Without a key the system
# falls back to pre-indexed mentions only — Discover still works.
# Get a free key at https://tavily.com (1000 searches/month on the free tier).
TAVILY_API_KEY=
